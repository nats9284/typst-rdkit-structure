# setup for the C rdkit-cffi interface

CC=emcc
CONFIGURE=emconfigure
EMMAKE=emmake
SOURCES=src1/main.c
INSTALLDIR=$(shell pwd)/install
BOOST_DOT_VERSION=1.87.0
RDBASEDIR=$(shell pwd)/rdkit
RDMINDIR=$(shell pwd)/rdkit/Code/MinimalLib
BOOSTSRCDIR=$(shell pwd)/boost
FTSRCDIR=$(shell pwd)/freetype
ZLIBSRCDIR=$(shell pwd)/zlib
CFLAGS = -Oz -flto=thin --no-entry -sFILESYSTEM=0 -sASSERTIONS=0 -sEXPORT_KEEPALIVE=1 -Wall -Wno-logical-op-parentheses -sWARN_ON_UNDEFINED_SYMBOLS=1 -sERROR_ON_UNDEFINED_SYMBOLS=0 -DDEBUG -DCOMPILE_ANSI_ONLY -sSTANDALONE_WASM 

INCLUDE_FLAGS = -I"src" -I"$(INSTALLDIR)/include" -L"$(INSTALLDIR)/lib" -lrdkitcffi -lRDKitDistGeomHelpers_static -lRDKitDistGeometry_static -lRDKitForceFieldHelpers_static -lRDKitForceField_static -lRDKitOptimizer_static -lRDKitTrajectory_static -lRDKitMolInterchange_static -lRDKitAbbreviations_static -lRDKitMolDraw2D_static -lRDKitDescriptors_static -lRDKitPartialCharges_static -lRDKitRGroupDecomposition_static -lRDKitFMCS_static -lRDKitga_static -lRDKitMolEnumerator_static -lRDKitTautomerQuery_static -lRDKitMolStandardize_static -lRDKitChemReactions_static -lRDKitFileParsers_static -lRDKitmaeparser_static -lRDKitFilterCatalog_static -lRDKitCatalogs_static -lRDKitChemTransforms_static -lRDKitFingerprints_static -lRDKitCIPLabeler_static -lRDKitSubgraphs_static -lRDKitRDInchiLib_static -lRDKitDepictor_static -lRDKitMolAlign_static -lRDKitAlignment_static -lRDKitMolTransforms_static -lRDKitEigenSolvers_static -lRDKitcoordgen_static -lRDKitSubstructMatch_static -lRDKitGenericGroups_static -lRDKitSmilesParse_static -lRDKitGraphMol_static -lRDKitRDGeometryLib_static -lRDKitDataStructs_static -lRDKitRDGeneral_static -lRDKitInchi_static -lRDKitRingDecomposerLib_static -lz

all: rdkit-structure.wasm

rdkit-structure.wasm: $(SOURCES) | $(RDBASEDIR)/build/lib/librdkitcffi.a
	cp $(RDBASEDIR)/build/lib/librdkitcffi.a $(RDBASEDIR)/build/Code/GraphMol/DistGeomHelpers/libRDKitDistGeomHelpers_static.a $(RDBASEDIR)/build/Code/DistGeom/libRDKitDistGeometry_static.a $(RDBASEDIR)/build/Code/GraphMol/ForceFieldHelpers/libRDKitForceFieldHelpers_static.a $(RDBASEDIR)/build/Code/ForceField/libRDKitForceField_static.a $(RDBASEDIR)/build/Code/Numerics/Optimizer/libRDKitOptimizer_static.a $(RDBASEDIR)/build/Code/GraphMol/Trajectory/libRDKitTrajectory_static.a $(RDBASEDIR)/build/Code/GraphMol/MolInterchange/libRDKitMolInterchange_static.a $(RDBASEDIR)/build/Code/GraphMol/Abbreviations/libRDKitAbbreviations_static.a $(RDBASEDIR)/build/Code/GraphMol/MolDraw2D/libRDKitMolDraw2D_static.a $(RDBASEDIR)/build/Code/GraphMol/Descriptors/libRDKitDescriptors_static.a $(RDBASEDIR)/build/Code/GraphMol/PartialCharges/libRDKitPartialCharges_static.a $(RDBASEDIR)/build/Code/GraphMol/RGroupDecomposition/libRDKitRGroupDecomposition_static.a $(RDBASEDIR)/build/Code/GraphMol/FMCS/libRDKitFMCS_static.a $(RDBASEDIR)/build/External/GA/libRDKitga_static.a $(RDBASEDIR)/build/Code/GraphMol/MolEnumerator/libRDKitMolEnumerator_static.a $(RDBASEDIR)/build/Code/GraphMol/TautomerQuery/libRDKitTautomerQuery_static.a $(RDBASEDIR)/build/Code/GraphMol/MolStandardize/libRDKitMolStandardize_static.a $(RDBASEDIR)/build/Code/GraphMol/ChemReactions/libRDKitChemReactions_static.a $(RDBASEDIR)/build/Code/GraphMol/FileParsers/libRDKitFileParsers_static.a $(RDBASEDIR)/build/External/CoordGen/libRDKitmaeparser_static.a $(RDBASEDIR)/build/Code/GraphMol/FilterCatalog/libRDKitFilterCatalog_static.a $(RDBASEDIR)/build/Code/Catalogs/libRDKitCatalogs_static.a $(RDBASEDIR)/build/Code/GraphMol/ChemTransforms/libRDKitChemTransforms_static.a $(RDBASEDIR)/build/Code/GraphMol/Fingerprints/libRDKitFingerprints_static.a $(RDBASEDIR)/build/Code/GraphMol/CIPLabeler/libRDKitCIPLabeler_static.a $(RDBASEDIR)/build/Code/GraphMol/Subgraphs/libRDKitSubgraphs_static.a $(RDBASEDIR)/build/External/INCHI-API/libRDKitRDInchiLib_static.a $(RDBASEDIR)/build/Code/GraphMol/Depictor/libRDKitDepictor_static.a $(RDBASEDIR)/build/Code/GraphMol/MolAlign/libRDKitMolAlign_static.a $(RDBASEDIR)/build/Code/Numerics/Alignment/libRDKitAlignment_static.a $(RDBASEDIR)/build/Code/GraphMol/MolTransforms/libRDKitMolTransforms_static.a $(RDBASEDIR)/build/Code/Numerics/EigenSolvers/libRDKitEigenSolvers_static.a $(RDBASEDIR)/build/External/CoordGen/libRDKitcoordgen_static.a $(RDBASEDIR)/build/Code/GraphMol/Substruct/libRDKitSubstructMatch_static.a $(RDBASEDIR)/build/Code/GraphMol/GenericGroups/libRDKitGenericGroups_static.a $(RDBASEDIR)/build/Code/GraphMol/SmilesParse/libRDKitSmilesParse_static.a $(RDBASEDIR)/build/Code/GraphMol/libRDKitGraphMol_static.a $(RDBASEDIR)/build/Code/Geometry/libRDKitRDGeometryLib_static.a $(RDBASEDIR)/build/Code/DataStructs/libRDKitDataStructs_static.a $(RDBASEDIR)/build/Code/RDGeneral/libRDKitRDGeneral_static.a $(RDBASEDIR)/build/External/INCHI-API/libRDKitInchi_static.a $(RDBASEDIR)/build/External/RingFamilies/libRDKitRingDecomposerLib_static.a $(INSTALLDIR)/lib/ ; \
	cp $(RDBASEDIR)/Code/MinimalLib/cffiwrapper.h $(INSTALLDIR)/include/; \
	cp -rf $(RDBASEDIR)/Code/RDGeneral $(INSTALLDIR)/include/; \
#
	$(CC) $(CFLAGS) $(SOURCES) $(INCLUDE_FLAGS) -o rdkit-structure.wasm 
#	wasi-stub --stub-function env:__syscall_unlinkat,env:__syscall_faccessat ./rdkit-structure.wasm -o rdkit-structure.wasm
	wasi-stub rdkit-structure.wasm -o rdkit-structure-stubbed.wasm --stub-module wasi_snapshot_preview1 

protocol src/protocol/protocol.c src/protocol/protocol.h: rdkit-structure.prot
	wasmpg rdkit-structure.prot -t . -c src/protocol

format:
	clang-format -i -style=file src/*.c src/*/*.c src/*/*.h

clean:
	rm -rf $(RDBASEDIR)
	rm -rf $(BOOSTSRCDIR)
	rm -rf $(FTSRCDIR)
	rm -rf $(ZLIBSRCDIR)
	rm -rf $(INSTALLDIR)
	rm -f *.wasm \
		 src/protocol/protocol.c \
		 src/protocol/protocol.h

$(RDBASEDIR)/build/lib/librdkitcffi.a: | $(RDMINDIR) $(INSTALLDIR)/lib/libz.a $(INSTALLDIR)/lib/libboost_system.a
	sed -i -e '1i \#ifdef DEBUG\n\#include <GraphMol/SmilesParse/SmilesWrite.h>\n\#endif' $(RDBASEDIR)/Code/GraphMol/RGroupDecomposition/RGroupFingerprintScore.cpp; \
	sed -i -e '1i \#ifdef DEBUG\n\#include <GraphMol/SmilesParse/SmilesWrite.h>\n\#endif' $(RDBASEDIR)/Code/GraphMol/RGroupDecomposition/RGroupScore.cpp; \
	sed -i -e 's/fingerprintVarianceGroupScore(fingerprintVarianceScoreData)/fingerprintVarianceScoreData.fingerprintVarianceGroupScore()/' $(RDBASEDIR)/Code/GraphMol/RGroupDecomposition/RGroupGa.cpp; \
	mkdir -p $(RDBASEDIR)/build; \
	cd $(RDBASEDIR)/build; \
	emcmake cmake -DCMAKE_BUILD_TYPE=Release -DRDK_BUILD_CPP_TESTS=OFF -DRDK_BUILD_PYTHON_WRAPPERS=OFF -DRDK_BUILD_COORDGEN_SUPPORT=ON -DRDK_BUILD_MAEPARSER_SUPPORT=ON -DRDK_OPTIMIZE_POPCNT=ON -DRDK_BUILD_INCHI_SUPPORT=ON -DRDK_BUILD_THREADSAFE_SSS=OFF -DRDK_TEST_MULTITHREADED=OFF -DRDK_BUILD_CFFI_LIB=ON -DRDK_USE_BOOST_SERIALIZATION=OFF -DCMAKE_POSITION_INDEPENDENT_CODE=ON -DRDK_INSTALL_COMIC_FONTS=OFF -DRDK_BUILD_FREETYPE_SUPPORT=OFF -DRDK_BUILD_MINIMAL_LIB=OFF -DRDK_URF_LIBS=ON -DBoost_DIR=$(INSTALLDIR)/lib/cmake/Boost-1.87.0 -Dboost_headers_DIR=$(INSTALLDIR)/lib/cmake/boost_headers-1.87.0 -DRDK_BUILD_SLN_SUPPORT=OFF -DRDK_USE_BOOST_IOSTREAMS=OFF -Dboost_serialization_DIR=$(INSTALLDIR)/lib/cmake/boost_serialization-1.87.0 -DZLIB_INCLUDE_DIR=$(INSTALLDIR)/include -DZLIB_LIBRARY=$(INSTALLDIR)/lib/libz.a -DCMAKE_INSTALL_PREFIX=$(INSTALLDIR) -DCMAKE_EXE_LINKER_FLAGS="-sASSERTIONS=0 -flto=thin" .. ; \
	cp $(RDBASEDIR)/External/INCHI-API/src/INCHI_BASE/src/util.c $(RDBASEDIR)/External/INCHI-API/src/INCHI_BASE/src/util.c.bak && \
 sed 's/&& defined(__APPLE__)//' $(RDBASEDIR)/External/INCHI-API/src/INCHI_BASE/src/util.c.bak > /$(RDBASEDIR)/External/INCHI-API/src/INCHI_BASE/src/util.c; \
	make VERBOSE=1 -j 2 rdkitcffi


$(INSTALLDIR)/lib/libboost_system.a: $(BOOSTSRCDIR) $(INSTALLDIR) $(BOOSTSRCDIR)/bootstrap.sh
	mkdir -p $(BOOSTSRCDIR)/build && cd $(BOOSTSRCDIR); \
	./bootstrap.sh --prefix=$(INSTALLDIR) --with-libraries=system; \
	./b2 toolset=emscripten link=static host-os=linux target-os=linux address-model=32 --with-system --build-dir=./build --prefix=$(INSTALLDIR) install

$(INSTALLDIR)/lib/libfreetyped.a: $(FTSRCDIR)| $(INSTALLDIR) $(FTSRCDIR)/Makefile
	mkdir -p $(FTSRCDIR)/build \
		&& cd $(FTSRCDIR)/build \
		&& emcmake cmake -DCMAKE_BUILD_TYPE=Debug -DFT_DISABLE_ZLIB=TRUE -DFT_DISABLE_BZIP2=TRUE -DFT_DISABLE_PNG=TRUE -DFT_DISABLE_HARFBUZZ=TRUE -DFT_DISABLE_BROTLI=TRUE -DCMAKE_C_FLAGS="" -DCMAKE_EXE_LINKER_FLAGS="-sASSERTIONS=0 -flto=thin" -DCMAKE_INSTALL_PREFIX=$(INSTALLDIR) ..; \
	make -j2 && make -j2 install



$(INSTALLDIR)/lib/libz.a: | $(ZLIBSRCDIR)/CMakeLists.txt $(INSTALLDIR)
	mkdir -p $(ZLIBSRCDIR)/build \
		&& cd $(ZLIBSRCDIR)/build; \
		emcmake cmake -DCMAKE_BUILD_TYPE=Release -DZLIB_BUILD_EXAMPLES=OFF -DBUILD_SHARED_LIBS=OFF -DCMAKE_INSTALL_PREFIX=$(INSTALLDIR) .. -DCMAKE_EXE_LINKER_FLAGS="-flto=thin -sASSERTIONS=0"; \

	make -j2 && make -j2 install

$(INSTALLDIR):
	mkdir -p $(INSTALLDIR) 

# download and extract rdkit source
$(RDMINDIR): | rdkit.tar.gz
	mkdir -p $(RDBASEDIR) 
	tar xf rdkit.tar.gz -C $(RDBASEDIR) --strip-components=1

rdkit.tar.gz:
	curl -L "https://github.com/rdkit/rdkit/archive/refs/tags/Release_2026_03_3.tar.gz" -o rdkit.tar.gz
# download and extract expat source

$(BOOSTSRCDIR) $(BOOSTSRCDIR)/CMakeLists.txt: | boost.tar.xz
	mkdir -p $(BOOSTSRCDIR)
	tar xf boost.tar.xz -C $(BOOSTSRCDIR) --strip-components=1

$(FTSRCDIR) $(FTSRCDIR)/CMakeLists.txt: | freetype.tar.gz
	mkdir -p $(FTSRCDIR)
	tar xf freetype.tar.gz -C $(FTSRCDIR) --strip-components=1

$(ZLIBSRCDIR) $(ZLIBSRCDIR)/CMakeLists.txt: | zlib.tar.gz
	mkdir -p $(ZLIBSRCDIR)
	tar xf zlib.tar.gz -C $(ZLIBSRCDIR) --strip-components=1
freetype.tar.gz:
	curl -L "https://gitlab.freedesktop.org/freetype/freetype/-/archive/VER-2-14-3/freetype-VER-2-14-3.tar.gz?ref_type=tags" -o freetype.tar.gz

zlib.tar.gz:
	curl -L "https://github.com/madler/zlib/releases/download/v1.3.2/zlib-1.3.2.tar.gz" -o zlib.tar.gz


boost.tar.xz:
	curl -L "https://github.com/boostorg/boost/releases/download/boost-1.87.0/boost-1.87.0-b2-nodocs.tar.xz" -o boost.tar.xz
